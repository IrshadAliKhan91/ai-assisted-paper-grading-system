# =============================================================================
# FairMark — single consolidated environment file
# Copy this file to backend/.env and fill in the values.
# ALL backend/server secrets live here (DB, grading, OCR).
# The frontend has its own build-time config in frontend/my-app/.env — do NOT
# put secret keys there (they are baked into the public browser bundle).
# =============================================================================

# --- Database ---------------------------------------------------------------
DATABASE_URL=sqlite:///./fairmark.db
API_PREFIX=/api

# --- Authentication (HTTP Basic Auth) ---------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=your_secure_password_here

# --- Grading: Google Gemini (primary LLM grader) ----------------------------
# Reference-answer generation tries Gemini first, then falls back to OpenRouter.
# Add _2 / _3 for multi-account failover when a free-tier key is rate-limited.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# --- Grading / OCR: Groq (Llama Vision) -------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# --- OCR: OpenRouter (primary vision OCR) -----------------------------------
# Add _2 / _3 for multi-account failover.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8010
OPENROUTER_APP_NAME=FairMark

# --- OCR: RapidAPI fallbacks ------------------------------------------------
PEN_TO_PRINT_API_KEY=your_pen_to_print_key_here
OCR_EXTRACT_API_KEY=your_ocr_extract_key_here
OCR_DOCUMENT_PRO_API_KEY=your_ocr_document_pro_key_here

# --- SBERT model ------------------------------------------------------------
# Set to all-mpnet-base-v2 for higher accuracy, then re-run generate_model_files.py
SBERT_MODEL=all-MiniLM-L6-v2

# --- Grading thresholds -----------------------------------------------------
# Fraction of max_marks required to count an answer as "correct" in stats (0.0-1.0)
CORRECT_ANSWER_THRESHOLD=0.7

# --- Misc -------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
# NLP model path override (optional — defaults to ../Grading Model/src relative to backend/)
# NLP_MODEL_PATH=/absolute/path/to/Grading Model/src
